# Required: Anthropic API key for LLM calls
ANTHROPIC_API_KEY=sk-ant-...

# Swarm run configuration
SWARM_INITIAL_PROMPT=Build an Instagram clone with auth, image feed, likes, and comments
SWARM_RUN_NAME=local-run
SWARM_MAX_LOOPS=3
SWARM_CONFIDENCE_THRESHOLD=0.85
SWARM_MODEL=anthropic/claude-sonnet-4-20250514

# Optional: comma-separated list of personas to use (empty = all)
SWARM_PERSONAS=

# Internal service URLs (set automatically by docker-compose)
# MEM0_API_URL=http://mem0:8080
# OPENCODE_HOST=opencode
# OPENCODE_PORT=4096
